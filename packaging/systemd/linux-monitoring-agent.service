[Unit]
Description=Linux Monitoring Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/linux-monitoring-agent -config /etc/linux-monitoring-agent/config.yaml
WorkingDirectory=/etc/linux-monitoring-agent
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
